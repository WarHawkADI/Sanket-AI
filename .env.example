NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=sanket123

# Recommended for Vercel's self-contained deterministic demo. Remove this only
# when NEO4J_URI points to a remotely reachable Neo4j instance (not localhost).
SANKET_FORCE_MEMSTORE=1

# Optional: comma-separated extra frontend origins. The bundled UI is same-origin.
# SANKET_CORS_ORIGINS=https://your-project.vercel.app

# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
